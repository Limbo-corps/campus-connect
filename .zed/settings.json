{
  "languages": {
    "Python": {
      "language_servers": ["basedpyright", "django"],
      "formatter": {
        "external": {
          "command": "ruff",
          "arguments": ["format", "-"],
        },
      },
      "format_on_save": "on",
    },
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "tailwindCSS": {
          "lint": {
            "suggestCanonicalClasses": "ignore",
          },
        },
      },
    },
  },
}
