SECRET_KEY=your-django-secret-key-here
DEBUG=True

POSTGRES_DB=campus_connect
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

GOOGLE_CLIENT_ID=your-google-oauth-client-id-here

# Help / contact form. CONTACT_EMAIL is the destination for messages and is kept
# server-side only — it is never exposed to the browser.
CONTACT_EMAIL=

# Email delivery. Leave EMAIL_BACKEND unset to use the console backend in dev
# (messages print to the backend terminal). For real delivery, use SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=your-sender@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=Campus Connect <your-sender@gmail.com>
